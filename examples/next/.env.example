# --- External server mode ---
# URL of your agent-browser API server
# Locally: http://localhost:3001
# Production: https://your-agent-browser-server.fly.dev
AGENT_BROWSER_API_URL=http://localhost:3001

# Optional: shared secret to authenticate requests
# AGENT_BROWSER_API_SECRET=your-secret-here

# --- Vercel Sandbox mode ---
# Snapshot ID with agent-browser + Chromium pre-installed (optional, speeds up startup)
# Create one with: npx tsx scripts/create-snapshot.ts
# AGENT_BROWSER_SNAPSHOT_ID=snap_xxxxxxxxxxxx
