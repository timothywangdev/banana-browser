{
  "name": "patchright-adapter",
  "version": "1.0.0",
  "description": "JSON-RPC adapter bridging agent-browser CLI to Patchright for anti-detection browser automation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "browser-automation",
    "patchright",
    "anti-detection",
    "json-rpc"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "patchright": "^1.49.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
